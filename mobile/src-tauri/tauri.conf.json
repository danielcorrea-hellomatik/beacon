{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Beacon",
  "version": "0.1.0",
  "identifier": "app.beacon.mobile",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Beacon",
        "width": 420,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        { "scheme": [ "beacon" ] }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ],
    "android": {
      "minSdkVersion": 24,
      "versionCode": 1
    }
  }
}

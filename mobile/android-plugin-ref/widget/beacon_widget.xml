<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout del widget Android. Pega como:
    src-tauri/gen/android/app/src/main/res/layout/beacon_widget.xml
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#A8A8AE"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:singleLine="true"
        android:ellipsize="end"
        android:text="Beacon"/>

    <TextView
        android:id="@+id/widget_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#D97757"
        android:textSize="28sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="2dp"
        android:singleLine="true"
        android:text="—"/>

    <TextView
        android:id="@+id/widget_sub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#F2F2F4"
        android:textSize="11sp"
        android:singleLine="true"
        android:layout_marginTop="2dp"
        android:text="Cargando…"/>

</LinearLayout>
